# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# Cloudflare Wrangler local secrets (Discord webhook 等の実値が入る・絶対にコミットしない)
.dev.vars
.dev.vars.*
.wrangler/

# secrets / keys (保険として一般的な鍵ファイルパターンを除外)
*.key
*.pfx
*-credentials.json
secrets.*

# backup / temp files
*.bak
ss-temp.cjs

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
public/assets/_backup/
