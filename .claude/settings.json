{
  "permissions": {
    "deny": [
      "Bash(rm -rf *)",
      "Bash(Remove-Item -Recurse -Force *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(*gentaai*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Read|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/block-gentaai.js"
          }
        ]
      }
    ]
  }
}
