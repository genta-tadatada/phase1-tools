{
  "permissions": {
    "allow": [
      "Bash(*)",
      "PowerShell(*)"
    ],
    "deny": [
      "Bash(*gentaai*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf /*)",
      "PowerShell(*gentaai*)",
      "PowerShell(*Format-Volume*)",
      "PowerShell(*Format-Disk*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Read|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/block-gentaai.js"
          }
        ]
      }
    ]
  }
}
